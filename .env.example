# Global Ontology Engine - Environment Variables
# Copy this file to .env and fill in your values

# ===================
# REQUIRED: API Keys
# ===================

# OpenRouter API Key (OpenAI-compatible; for GPT models, NER, entity linking, relation extraction)
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# News API Key (get from https://newsapi.org)
NEWS_API_KEY=your_newsapi_key_here

# ===================
# Database Connections
# ===================

# Neo4j Graph Database
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=  # REQUIRED: Set a strong password for Neo4j

# PostgreSQL (for structured data, articles, logs)
POSTGRES_USER=ontology_user
POSTGRES_PASSWORD=  # REQUIRED: Set a strong password for PostgreSQL
POSTGRES_DB=ontology_db
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@localhost:5432/${POSTGRES_DB}

# Redis (for caching, pub/sub, session management)
REDIS_URL=redis://localhost:6379/0

# ===================
# Backend Configuration
# ===================

# Backend Service
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_DEBUG=false
BACKEND_RELOAD=false

# CORS Settings (comma-separated origins)
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===================
# AI/ML Configuration
# ===================

# OpenAI Model Settings
OPENAI_MODEL=gpt-4-turbo-preview
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_MAX_TOKENS=2000
OPENAI_TEMPERATURE=0.7

# GraphRAG Configuration
GRAPHRAG_TOP_K=5
GRAPHRAG_MAX_HOPS=3
GRAPHRAG_SIMILARITY_THRESHOLD=0.75

# ===================
# Data Ingestion
# ===================

# RSS Feed URLs are configured in backend/app/config.py by default.

# Ingestion Settings
INGESTION_INTERVAL_MINUTES=30
ARTICLES_PER_CYCLE=50
ENTITY_EXTRACTION_ENABLED=true

# ===================
# Celery Configuration
# ===================

# Celery Broker & Result Backend
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
CELERY_TASK_SERIALIZER=json
CELERY_RESULT_SERIALIZER=json
CELERY_ACCEPT_CONTENT=json
CELERY_TIMEZONE=UTC
CELERY_ENABLE_UTC=true

# Celery Beat Schedule
CELERY_BEAT_SCHEDULE_ENABLED=true

# ===================
# Frontend Configuration
# ===================

# Frontend (Vite)
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ===================
# Logging & Monitoring
# ===================

# Log Level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Enable API Request Logging
LOG_REQUESTS=true

# ===================
# Security
# ===================

# Secret Key for JWT/Sessions (generate a strong random string)
SECRET_KEY=your_secret_key_here_change_in_production

# Session Expiry (in minutes)
SESSION_EXPIRY_MINUTES=60
